---

const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL as string;
const ADMIN_TOKEN = import.meta.env.DIRECTUS_SERVER_TOKEN as string;
const GOOGLE_ROLE_ID = '0ef5375a-2de5-4e25-bcd4-3eecfcca53b8';
const GOOGLE_POLICY_ID = '32a88764-75b9-4d17-a740-0d9852186858';

interface AuthResult {
  redirect: string;
  cookieValue: string | null;
  error: string | null;
}

const adminFetch = (path: string, init?: RequestInit) =>
  fetch(`${DIRECTUS_URL}${path}`, {
    ...init,
    headers: {
      Authorization: `Bearer ${ADMIN_TOKEN}`,
      'Content-Type': 'application/json',
      ...(init?.headers as Record<string, string> | undefined),
    },
  });

const ensureUserConfig = async (userId: string): Promise<any> => {
  const usersRes = await adminFetch(
    `/users/${userId}?fields=id,role`,
  );
  if (!usersRes.ok) return null;

  const usersData = await usersRes.json().catch(() => null);
  const user = usersData?.data;
  if (!user) return null;

  if (user.role !== GOOGLE_ROLE_ID) {
    await adminFetch(`/users/${userId}`, {
      method: 'PATCH',
      body: JSON.stringify({ role: GOOGLE_ROLE_ID }),
    });
  }

  const accessRes = await adminFetch(
    `/items/directus_access?fields=id&filter[user][_eq]=${userId}&filter[policy][_eq]=${GOOGLE_POLICY_ID}&limit=1`,
  );
  const accessData = await accessRes.json().catch(() => null);
  const existingLinks = accessData?.data ?? [];

  if (!existingLinks[0]) {
    await adminFetch('/items/directus_access', {
      method: 'POST',
      body: JSON.stringify({
        user: userId,
        role: GOOGLE_ROLE_ID,
        policy: GOOGLE_POLICY_ID,
      }),
    });
  }

  return user;
};

const processExchange = async (token: string): Promise<AuthResult & { debugStep?: string }> => {
  const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL as string;

  // Step 1: /token-exchange
  let exchangeRes: Response;
  try {
    exchangeRes = await fetch(`${DIRECTUS_URL}/token-exchange`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token }),
    });
  } catch (err: any) {
    return { redirect: '', cookieValue: null, error: `exchange_network:${err.message}` };
  }

  if (!exchangeRes.ok) {
    const errBody = await exchangeRes.text().catch(() => '');
    return { redirect: '', cookieValue: null, error: `exchange_http_${exchangeRes.status}:${errBody.slice(0, 200)}` };
  }

  const exchangeData = await exchangeRes.json().catch(() => null);
  if (!exchangeData) {
    return { redirect: '', cookieValue: null, error: 'exchange_json_parse_failed' };
  }
  const refreshToken = exchangeData?.refreshToken;
  if (!refreshToken) {
    return { redirect: '', cookieValue: null, error: `exchange_no_refresh:${JSON.stringify(exchangeData).slice(0, 200)}` };
  }

  // Step 2: /auth/refresh
  let refreshRes: Response;
  try {
    refreshRes = await fetch(`${DIRECTUS_URL}/auth/refresh`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ refresh_token: refreshToken, mode: 'json' }),
    });
  } catch (err: any) {
    return { redirect: '', cookieValue: null, error: `refresh_network:${err.message}` };
  }

  if (!refreshRes.ok) {
    const errBody = await refreshRes.text().catch(() => '');
    return { redirect: '', cookieValue: null, error: `refresh_http_${refreshRes.status}:${errBody.slice(0, 200)}` };
  }

  const refreshData = await refreshRes.json().catch(() => null);
  if (!refreshData) {
    return { redirect: '', cookieValue: null, error: 'refresh_json_parse_failed' };
  }
  const accessToken = refreshData?.data?.access_token;
  if (!accessToken) {
    return { redirect: '', cookieValue: null, error: `refresh_no_token:${JSON.stringify(refreshData).slice(0, 200)}` };
  }

  // Step 3: fetch user via /users/me with explicit fields (Customer role has auto-join on posts causing INVALID_QUERY)
  let user: any;
  try {
    const meRes = await fetch(`${DIRECTUS_URL}/users/me?fields=id,email,first_name,last_name`, {
      headers: {
        Authorization: `Bearer ${accessToken}`,
      },
    });
    if (!meRes.ok) {
      const errBody = await meRes.text().catch(() => '');
      return { redirect: '', cookieValue: null, error: `me_http_${meRes.status}:${errBody.slice(0, 200)}` };
    }
    const meData = await meRes.json().catch(() => null);
    user = meData?.data;
  } catch (err: any) {
    return { redirect: '', cookieValue: null, error: `me_network:${err.message}` };
  }
  if (!user) {
    return { redirect: '', cookieValue: null, error: 'user_not_found' };
  }

  // Step 4: ensureUserConfig
  try {
    await ensureUserConfig(user.id);
  } catch (err: any) {
    return { redirect: '', cookieValue: null, error: `config:${err.message}` };
  }

  // Step 5: contacts (use adminFetch)
  let contact: any = null;
  try {
    const cRes = await adminFetch(
      `/items/contacts?fields=id,phone&filter[user][_eq]=${user.id}&limit=1`,
    );
    if (!cRes.ok) {
      return { redirect: '', cookieValue: null, error: `contact_read_http_${cRes.status}` };
    }
    const cData = await cRes.json().catch(() => null);
    contact = cData?.data?.[0] ?? null;
  } catch (err: any) {
    return { redirect: '', cookieValue: null, error: `contact_read:${err.message}` };
  }

  if (!contact) {
    try {
      const createRes = await adminFetch('/items/contacts', {
        method: 'POST',
        body: JSON.stringify({
          user: user.id,
          email: user.email,
          first_name: user.first_name,
          last_name: user.last_name,
        }),
      });
      if (!createRes.ok) {
        const errBody = await createRes.text().catch(() => '');
        return { redirect: '', cookieValue: null, error: `contact_create_http_${createRes.status}:${errBody.slice(0, 200)}` };
      }
      const createData = await createRes.json().catch(() => null);
      contact = createData?.data;
    } catch (err: any) {
      return { redirect: '', cookieValue: null, error: `contact_create:${err.message}` };
    }
  }

  const destination = contact?.phone
    ? '/tai-khoan'
    : '/tai-khoan/cap-nhat-thong-tin';

  const cookieValue = `auth_token=${accessToken}; HttpOnly; Secure; SameSite=None; Path=/; Max-Age=604800`;

  return { redirect: destination, cookieValue, error: null };
};

const token = Astro.url.searchParams.get('token');
const type = Astro.url.searchParams.get('type');
const errorParam = Astro.url.searchParams.get('error');
const reason = Astro.url.searchParams.get('reason');

let result: AuthResult & { debugStep?: string } = { redirect: '', cookieValue: null, error: null };

if (errorParam === 'true') {
  result.error = reason || 'sso_error';
} else if (type === 'exchange' && token) {
  result = await processExchange(token);
} else {
  result.error = 'invalid_request';
}

if (result.redirect && result.cookieValue) {
  return new Response(null, {
    status: 302,
    headers: {
      Location: result.redirect,
      'Set-Cookie': result.cookieValue,
    },
  });
}
---

<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Hồng Ngọc Huyền Học</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body class="min-h-screen bg-[#faf6f5] flex items-center justify-center font-sans">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8 border border-[#f5e1e0] text-center">
      <h1 class="text-xl font-bold text-[#1f2a1d] mb-4">
        {result.error ? 'Đăng nhập thất bại' : 'Đang xử lý...'}
      </h1>
      <p class="text-sm text-[#6b7a65] mb-2">
        {result.error
          ? 'Có lỗi xảy ra trong quá trình đăng nhập. Vui lòng thử lại.'
          : 'Đang xử lý đăng nhập, vui lòng đợi...'}
      </p>
      {result.error && (
        <details class="mb-6">
          <summary class="text-xs text-red-500 cursor-pointer">Chi tiết lỗi</summary>
          <p class="text-xs text-red-400 mt-1 bg-red-50 p-2 rounded break-all">{result.error}</p>
        </details>
      )}
      {result.error && (
        <a
          href="/login"
          class="inline-block bg-[#1f2a1d] text-white font-medium py-2 px-6 rounded-xl hover:bg-[#2f3a2d] transition-colors"
        >
          Thử lại
        </a>
      )}
    </div>
  </body>
</html>
