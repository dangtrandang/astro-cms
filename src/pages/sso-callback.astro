---
import { AUTH_COOKIE_NAME, AUTH_COOKIE_OPTIONS } from '@/lib/auth-cookie';
 
const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL as string;
const ADMIN_TOKEN = import.meta.env.DIRECTUS_SERVER_TOKEN as string;
const GOOGLE_ROLE_ID = '0ef5375a-2de5-4e25-bcd4-3eecfcca53b8';
const GOOGLE_POLICY_ID = '32a88764-75b9-4d17-a740-0d9852186858';

interface AuthResult {
  redirect: string;
  accessToken: string | null;
  error: string | null;
}

const adminFetch = (path: string, init?: RequestInit) =>
  fetch(`${DIRECTUS_URL}${path}`, {
    ...init,
    headers: {
      Authorization: `Bearer ${ADMIN_TOKEN}`,
      'Content-Type': 'application/json',
      ...(init?.headers as Record<string, string> | undefined),
    },
  });

const ensureUserConfig = async (userId: string): Promise<any> => {
  const usersRes = await adminFetch(
    `/users/${userId}?fields=id,role`,
  );
  if (!usersRes.ok) return null;

  const usersData = await usersRes.json().catch(() => null);
  const user = usersData?.data;
  if (!user) return null;

  if (user.role !== GOOGLE_ROLE_ID) {
    await adminFetch(`/users/${userId}`, {
      method: 'PATCH',
      body: JSON.stringify({ role: GOOGLE_ROLE_ID }),
    });
  }

  const accessFilter = encodeURIComponent(JSON.stringify({ user: { _eq: userId }, policy: { _eq: GOOGLE_POLICY_ID } }));
  const accessRes = await adminFetch(
    `/items/directus_access?fields=id&filter=${accessFilter}&limit=1`,
  );
  const accessData = await accessRes.json().catch(() => null);
  const existingLinks = accessData?.data ?? [];

  if (!existingLinks[0]) {
    await adminFetch('/items/directus_access', {
      method: 'POST',
      body: JSON.stringify({
        user: userId,
        role: GOOGLE_ROLE_ID,
        policy: GOOGLE_POLICY_ID,
      }),
    });
  }

  return user;
};

const processExchange = async (token: string): Promise<AuthResult> => {
  const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL as string;

  // Step 1: /token-exchange
  let exchangeRes: Response;
  try {
    exchangeRes = await fetch(`${DIRECTUS_URL}/token-exchange`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ token }),
    });
  } catch (err: any) {
    return { redirect: '', accessToken: null, error: `exchange_network:${err.message}` };
  }

  if (!exchangeRes.ok) {
    const errBody = await exchangeRes.text().catch(() => '');
    return { redirect: '', accessToken: null, error: `exchange_http_${exchangeRes.status}:${errBody.slice(0, 200)}` };
  }

  const exchangeData = await exchangeRes.json().catch(() => null);
  if (!exchangeData) {
    return { redirect: '', accessToken: null, error: 'exchange_json_parse_failed' };
  }
  const refreshToken = exchangeData?.refreshToken;
  if (!refreshToken) {
    return { redirect: '', accessToken: null, error: `exchange_no_refresh:${JSON.stringify(exchangeData).slice(0, 200)}` };
  }

  // Step 2: /auth/refresh
  let refreshRes: Response;
  try {
    refreshRes = await fetch(`${DIRECTUS_URL}/auth/refresh`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ refresh_token: refreshToken, mode: 'json' }),
    });
  } catch (err: any) {
    return { redirect: '', accessToken: null, error: `refresh_network:${err.message}` };
  }

  if (!refreshRes.ok) {
    const errBody = await refreshRes.text().catch(() => '');
    return { redirect: '', accessToken: null, error: `refresh_http_${refreshRes.status}:${errBody.slice(0, 200)}` };
  }

  const refreshData = await refreshRes.json().catch(() => null);
  if (!refreshData) {
    return { redirect: '', accessToken: null, error: 'refresh_json_parse_failed' };
  }
  const accessToken = refreshData?.data?.access_token;
  if (!accessToken) {
    return { redirect: '', accessToken: null, error: `refresh_no_token:${JSON.stringify(refreshData).slice(0, 200)}` };
  }

  // Step 3: fetch userId via /users/me (user token) then admin token for full fields
  let user: any;
  try {
    const meRes = await fetch(`${DIRECTUS_URL}/users/me?fields=id,email,first_name,last_name`, {
      headers: {
        Authorization: `Bearer ${accessToken}`,
      },
    });
    if (!meRes.ok) {
      const errBody = await meRes.text().catch(() => '');
      return { redirect: '', accessToken: null, error: `me_http_${meRes.status}:${errBody.slice(0, 200)}` };
    }
    const meData = await meRes.json().catch(() => null);
    const userId = meData?.data?.id;
    if (!userId) {
      return { redirect: '', accessToken: null, error: 'user_not_found' };
    }

    const adminUserRes = await adminFetch(`/users/${userId}?fields=id,email,first_name,last_name,provider`);
    if (!adminUserRes.ok) {
      const errBody = await adminUserRes.text().catch(() => '');
      return { redirect: '', accessToken: null, error: `admin_user_http_${adminUserRes.status}:${errBody.slice(0, 200)}` };
    }
    const adminUserData = await adminUserRes.json().catch(() => null);
    user = adminUserData?.data;
  } catch (err: any) {
    return { redirect: '', accessToken: null, error: `me_network:${err.message}` };
  }
  if (!user) {
    return { redirect: '', accessToken: null, error: 'user_not_found' };
  }

  // Step 3b: Provider mismatch check — if user was registered via email/password, reject Google SSO
  if (user.provider && user.provider !== 'google') {
    return { redirect: `/login?error=google_blocked&reason=${encodeURIComponent('Tài khoản này được bảo mật bằng mật khẩu. Vui lòng nhập mật khẩu của bạn.')}`, accessToken: null, error: null };
  }

  // Step 4: ensureUserConfig
  try {
    await ensureUserConfig(user.id);
  } catch (err: any) {
    return { redirect: '', accessToken: null, error: `config:${err.message}` };
  }

  // Step 5: contacts — try POST, if RECORD_NOT_UNIQUE then re-fetch existing
  let contact: any = null;

  try {
    const createRes = await adminFetch('/items/contacts', {
      method: 'POST',
      body: JSON.stringify({
        user: user.id,
        email: user.email,
        first_name: user.first_name,
        last_name: user.last_name,
      }),
    });
    if (createRes.ok) {
      const createData = await createRes.json().catch(() => null);
      contact = createData?.data;
    } else {
      const errBody = await createRes.text().catch(() => '');
      if (errBody.includes('RECORD_NOT_UNIQUE')) {
        const contactFilter = encodeURIComponent(JSON.stringify({ user: { _eq: user.id } }));
        const cRes = await adminFetch(`/items/contacts?fields=id,phone&filter=${contactFilter}&limit=1`);
        if (cRes.ok) {
          const cData = await cRes.json().catch(() => null);
          contact = cData?.data?.[0] ?? null;
        }
      }
      if (!contact) {
        return { redirect: '', accessToken: null, error: `contact_http_${createRes.status}:${errBody.slice(0, 200)}` };
      }
    }
  } catch (err: any) {
    return { redirect: '', accessToken: null, error: `contact:${err.message}` };
  }

  // Step 5b: Create user_registrations record to trigger welcome + admin flows
  // For Google SSO users, store a placeholder since there's no password
  try {
    const fullName = [user.first_name, user.last_name].filter(Boolean).join(' ') || user.email;
    await adminFetch('/items/user_registrations', {
      method: 'POST',
      body: JSON.stringify({
        name: fullName,
        email: user.email,
        password: user.provider === 'google' ? `sso:${user.provider}:${user.id}` : 'sso:google',
      }),
    });
  } catch {
    // non-fatal
  }
  const destination = '/tai-khoan';

  return { redirect: destination, accessToken, error: null };
};

const token = Astro.url.searchParams.get('token');
const type = Astro.url.searchParams.get('type');
const errorParam = Astro.url.searchParams.get('error');
const reason = Astro.url.searchParams.get('reason');

let result: AuthResult & { debugStep?: string } = { redirect: '', accessToken: null, error: null };

if (errorParam === 'true') {
  const msgMap: Record<string, string> = {
    INVALID_PROVIDER: 'Tài khoản này được bảo mật bằng mật khẩu. Vui lòng nhập mật khẩu của bạn.',
  };
  const friendly = msgMap[reason || ''] || (reason || 'sso_error');
  return Astro.redirect(`/login?error=google_blocked&reason=${encodeURIComponent(friendly)}`);
} else if (type === 'exchange' && token) {
  result = await processExchange(token);
} else {
  result.error = 'invalid_request';
}

if (result.redirect && result.accessToken) {
  Astro.cookies.set(AUTH_COOKIE_NAME, result.accessToken, AUTH_COOKIE_OPTIONS);
  return Astro.redirect(result.redirect);
}

if (result.redirect && !result.accessToken) {
  return Astro.redirect(result.redirect);
}
---

<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Hồng Ngọc Huyền Học</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>
  <body class="min-h-screen bg-[#faf6f5] flex items-center justify-center font-sans">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8 border border-[#f5e1e0] text-center">
      <h1 class="text-xl font-bold text-[#1f2a1d] mb-4">
        {result.error ? 'Đăng nhập thất bại' : 'Đang xử lý...'}
      </h1>
      <p class="text-sm text-[#6b7a65] mb-2">
        {result.error
          ? 'Có lỗi xảy ra trong quá trình đăng nhập. Vui lòng thử lại.'
          : 'Đang xử lý đăng nhập, vui lòng đợi...'}
      </p>
      {result.error && (
        <a
          href="/login"
          class="inline-block bg-[#1f2a1d] text-white font-medium py-2 px-6 rounded-xl hover:bg-[#2f3a2d] transition-colors"
        >
          Thử lại
        </a>
      )}
    </div>
  </body>
</html>
