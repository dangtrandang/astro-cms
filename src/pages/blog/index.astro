---
import Layout from '@/layouts/BaseLayout.astro';
import { fetchBlogArchiveData, fetchCategories, fetchPageBlogSeo } from '@/lib/directus/fetchers';
import BlogArchive from '@/components/blocks/BlogArchive';

export const prerender = false;

const [{ posts, totalCount, totalPages }, rawCategories, pageBlogSeo] = await Promise.all([
  fetchBlogArchiveData(1),
  fetchCategories(),
  fetchPageBlogSeo(),
]);

const categories = rawCategories.map((cat: any) => ({ categories_id: cat }));

const blogArchiveData = {
  id: 'blog-index',
  posts,
  totalCount,
  totalPages,
  categories,
};

const siteURL = import.meta.env.PUBLIC_SITE_URL || '';

// SEO: Directus-first. page_blog.seo → fallback to hardcoded defaults.
// Currently page_blog.seo is null in the CMS; hardcoded values serve as fallback.
const seoTitle = pageBlogSeo?.title ?? 'Blog';
const seoDesc = pageBlogSeo?.meta_description ?? 'Các bài viết về huyền học, tarot và chiêm nghiệm cuộc sống';

const metadata: any = {
  title: seoTitle,
  description: seoDesc,
  openGraph: {
    title: seoTitle,
    description: seoDesc,
    url: `${siteURL}/blog`,
    type: 'website',
  },
};

// Only pass robots if explicitly set in Directus (no_index or no_follow)
if (pageBlogSeo?.no_index || pageBlogSeo?.no_follow) {
  const parts: string[] = [];
  if (pageBlogSeo.no_index) parts.push('noindex');
  if (pageBlogSeo.no_follow) parts.push('nofollow');
  if (parts.length) metadata.robots = parts.join(', ');
}

if (pageBlogSeo?.canonical_url) {
  metadata.canonical = pageBlogSeo.canonical_url;
}
---

<Layout metadata={metadata}>
  <BlogArchive client:load data={blogArchiveData} />
</Layout>
