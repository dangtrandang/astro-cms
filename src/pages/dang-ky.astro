---
import Layout from '@/layouts/BaseLayout.astro';

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL as string;
---

<Layout metadata={{ title: 'Đăng ký', description: 'Đăng ký tài khoản Hồng Ngọc Huyền Học' }}>
  <div id="register-page" data-directus-url={directusUrl} class="min-h-[70vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8 border border-[#f5e1e0]">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-[#1f2a1d] mb-2">Đăng ký</h1>
        <p class="text-sm text-[#6b7a65]">Tạo tài khoản mới tại Hồng Ngọc Huyền Học</p>
        <div id="register-err" class="text-sm text-red-500 mt-2 hidden"></div>
        <div id="register-ok" class="text-sm text-green-600 mt-2 hidden"></div>
      </div>

      <form id="register-form" class="space-y-4">
        <div class="flex gap-3">
          <div class="flex-1">
            <label for="reg_first_name" class="block text-sm font-medium text-[#1f2a1d] mb-1">Họ</label>
            <input
              type="text"
              id="reg_first_name"
              name="first_name"
              autocomplete="given-name"
              class="w-full px-4 py-2.5 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#C6DCE4]/30 focus:border-[#C6DCE4] outline-none transition"
            />
          </div>
          <div class="flex-1">
            <label for="reg_last_name" class="block text-sm font-medium text-[#1f2a1d] mb-1">Tên</label>
            <input
              type="text"
              id="reg_last_name"
              name="last_name"
              autocomplete="family-name"
              class="w-full px-4 py-2.5 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#C6DCE4]/30 focus:border-[#C6DCE4] outline-none transition"
            />
          </div>
        </div>

        <div>
          <label for="reg_email" class="block text-sm font-medium text-[#1f2a1d] mb-1">Email <span class="text-red-400">*</span></label>
          <input
            type="email"
            id="reg_email"
            name="email"
            required
            autocomplete="email"
            placeholder="VD: ban@example.com"
            class="w-full px-4 py-2.5 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#C6DCE4]/30 focus:border-[#C6DCE4] outline-none transition"
          />
        </div>

        <div>
          <label for="reg_password" class="block text-sm font-medium text-[#1f2a1d] mb-1">Mật khẩu <span class="text-red-400">*</span></label>
          <div class="relative">
            <input
              type="password"
              id="reg_password"
              name="password"
              required
              minlength="8"
              autocomplete="new-password"
              placeholder="Ít nhất 8 ký tự"
              class="w-full px-4 py-2.5 pr-10 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#C6DCE4]/30 focus:border-[#C6DCE4] outline-none transition"
            />
            <button
              type="button"
              id="reg-toggle-pw"
              class="absolute right-3 top-1/2 -translate-y-1/2 text-[#9bab92] hover:text-[#4a5a40] focus:outline-none"
              tabindex="-1"
              aria-label="Hiển thị mật khẩu"
            >
              <svg id="reg-eye-off" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                <line x1="1" y1="1" x2="23" y2="23" />
              </svg>
              <svg id="reg-eye-on" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </button>
          </div>
        </div>

        <div>
          <label for="reg_confirm_password" class="block text-sm font-medium text-[#1f2a1d] mb-1">Xác nhận mật khẩu <span class="text-red-400">*</span></label>
          <input
            type="password"
            id="reg_confirm_password"
            name="confirm_password"
            required
            minlength="8"
            autocomplete="new-password"
            placeholder="Nhập lại mật khẩu"
            class="w-full px-4 py-2.5 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#C6DCE4]/30 focus:border-[#C6DCE4] outline-none transition"
          />
        </div>

        <button
          type="submit"
          id="register-submit"
          class="w-full bg-[#1f2a1d] hover:bg-[#2f3a2d] disabled:bg-[#9bab92] text-white font-medium py-3 px-6 rounded-full transition-colors"
        >
          Đăng ký
        </button>
      </form>

      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-[#f5e1e0]"></div></div>
        <div class="relative flex justify-center text-xs"><span class="bg-white px-3 text-[#9bab92]">hoặc</span></div>
      </div>

      <a
        href={`${directusUrl}/sso-auth/google/dev`}
        class="flex items-center justify-center gap-3 w-full bg-white border border-gray-300 hover:border-gray-400 hover:shadow-sm text-gray-700 font-medium py-3 px-4 rounded-xl transition-all"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
        </svg>
        Đăng ký nhanh với Google
      </a>

      <p class="text-center text-sm text-[#9bab92] mt-6">
        Đã có tài khoản? <a href="/login" class="text-[#c0395b] hover:underline font-medium">Đăng nhập</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('register-form') as HTMLFormElement;
  const errEl = document.getElementById('register-err')!;
  const okEl = document.getElementById('register-ok')!;
  const submitBtn = document.getElementById('register-submit') as HTMLButtonElement;

  // Password toggle
  const toggleBtn = document.getElementById('reg-toggle-pw') as HTMLButtonElement;
  const pwInput = document.getElementById('reg_password') as HTMLInputElement;
  const eyeOff = document.getElementById('reg-eye-off')!;
  const eyeOn = document.getElementById('reg-eye-on')!;

  toggleBtn.addEventListener('click', () => {
    const isPassword = pwInput.type === 'password';
    pwInput.type = isPassword ? 'text' : 'password';
    eyeOff.classList.toggle('hidden', isPassword);
    eyeOn.classList.toggle('hidden', !isPassword);
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errEl.classList.add('hidden');
    okEl.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Đang xử lý...';

    const formData = new FormData(form);
    const password = formData.get('password')?.toString() || '';
    const confirm = formData.get('confirm_password')?.toString() || '';
    const body = {
      first_name: formData.get('first_name')?.toString().trim() || '',
      last_name: formData.get('last_name')?.toString().trim() || '',
      email: formData.get('email')?.toString().trim() || '',
      password,
    };

    if (!body.email || !password) {
      errEl.textContent = 'Vui lòng nhập đầy đủ Email và Mật khẩu';
      errEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Đăng ký';
      return;
    }

    if (password.length < 8) {
      errEl.textContent = 'Mật khẩu phải có ít nhất 8 ký tự';
      errEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Đăng ký';
      return;
    }

    if (password !== confirm) {
      errEl.textContent = 'Mật khẩu xác nhận không khớp';
      errEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Đăng ký';
      return;
    }

    try {
      const res = await fetch('/api/auth/register', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      const data = await res.json().catch(() => null);

      if (res.ok && data?.redirect) {
        okEl.textContent = 'Đăng ký thành công! Đang chuyển hướng...';
        okEl.classList.remove('hidden');
        setTimeout(() => {
          window.location.href = data.redirect;
        }, 800);
      } else if (res.ok && data?.success) {
        okEl.textContent = 'Đăng ký thành công! Vui lòng đăng nhập.';
        okEl.classList.remove('hidden');
        setTimeout(() => {
          window.location.href = '/login';
        }, 1500);
      } else {
        errEl.textContent = data?.error || 'Đăng ký thất bại, vui lòng thử lại';
        errEl.classList.remove('hidden');
      }
    } catch (err) {
      errEl.textContent = 'Lỗi kết nối, vui lòng thử lại';
      errEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Đăng ký';
    }
  });
</script>
