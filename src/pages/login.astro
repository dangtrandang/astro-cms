---
import Layout from '@/layouts/BaseLayout.astro';

const directusUrl = import.meta.env.PUBLIC_DIRECTUS_URL as string;
const recaptchaSiteKey = import.meta.env.PUBLIC_RECAPTCHA_SITE_KEY as string;
---

<Layout metadata={{ title: 'Đăng nhập', description: 'Đăng nhập vào tài khoản Hồng Ngọc Huyền Học' }}>
  <div id="login-page" data-directus-url={directusUrl} data-recaptcha-site-key={recaptchaSiteKey} class="min-h-[70vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8 border border-[#f5e1e0]">
      <div class="text-center mb-8">
        <h1 id="login-title" class="text-2xl font-bold text-[#1f2a1d] mb-2">Đăng nhập</h1>
        <p id="login-msg" class="text-sm text-[#6b7a65]">Chào mừng bạn quay lại Hồng Ngọc Huyền Học</p>
        <div id="login-err" class="text-sm text-red-500 mt-2 hidden"></div>
      </div>

      <!-- Email/Password Form -->
      <form id="login-form" class="space-y-4">
        <div>
          <label for="login_email" class="block text-sm font-medium text-[#1f2a1d] mb-1">Email</label>
          <input
            type="email"
            id="login_email"
            name="email"
            required
            autocomplete="email"
            placeholder="VD: ban@example.com"
            class="w-full px-4 py-2.5 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#c0395b]/30 focus:border-[#c0395b] outline-none transition"
          />
        </div>

        <div>
          <label for="login_password" class="block text-sm font-medium text-[#1f2a1d] mb-1">Mật khẩu</label>
          <div class="relative">
            <input
              type="password"
              id="login_password"
              name="password"
              required
              autocomplete="current-password"
              placeholder="Nhập mật khẩu"
              class="w-full px-4 py-2.5 pr-10 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#c0395b]/30 focus:border-[#c0395b] outline-none transition"
            />
            <button
              type="button"
              id="login-toggle-pw"
              class="absolute right-3 top-1/2 -translate-y-1/2 text-[#9bab92] hover:text-[#4a5a40] focus:outline-none"
              tabindex="-1"
              aria-label="Hiển thị mật khẩu"
            >
              <svg id="login-eye-off" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                <line x1="1" y1="1" x2="23" y2="23" />
              </svg>
              <svg id="login-eye-on" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            </button>
          </div>
        </div>

        <button
          type="submit"
          id="login-submit"
          class="w-full bg-[#1f2a1d] hover:bg-[#2f3a2d] disabled:bg-[#9bab92] text-white font-medium py-3 px-6 rounded-full transition-colors"
        >
          Đăng nhập
        </button>

        <p class="text-right mt-1">
          <button type="button" id="forgot-pw-link" class="text-xs text-[#c0395b] hover:underline">Quên mật khẩu?</button>
        </p>
      </form>

      <form id="forgot-pw-form" class="hidden space-y-4 mt-6 pt-6 border-t border-[#f5e1e0]">
        <p class="text-sm text-[#6b7a65]">Nhập email của bạn, chúng tôi sẽ gửi hướng dẫn đặt lại mật khẩu.</p>
        <div>
          <label for="forgot_email" class="block text-sm font-medium text-[#1f2a1d] mb-1">Email</label>
          <input
            type="email"
            id="forgot_email"
            name="email"
            required
            autocomplete="email"
            placeholder="VD: ban@example.com"
            class="w-full px-4 py-2.5 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#c0395b]/30 focus:border-[#c0395b] outline-none transition"
          />
        </div>
        <div id="forgot-msg" class="text-xs hidden"></div>
        <div class="flex gap-2">
          <button type="button" id="forgot-back" class="flex-1 border border-[#e8d5d5] text-[#6b7a65] font-medium py-2.5 px-4 rounded-full hover:bg-gray-50 transition-colors text-sm">Quay lại</button>
          <button type="submit" id="forgot-submit" class="flex-1 bg-[#1f2a1d] hover:bg-[#2f3a2d] disabled:bg-[#9bab92] text-white font-medium py-2.5 px-4 rounded-full transition-colors text-sm">Gửi yêu cầu</button>
        </div>
      </form>

      <div class="relative my-6">
        <div class="absolute inset-0 flex items-center"><div class="w-full border-t border-[#f5e1e0]"></div></div>
        <div class="relative flex justify-center text-xs"><span class="bg-white px-3 text-[#9bab92]">hoặc</span></div>
      </div>

      <a
        id="login-btn-google"
        href={`${directusUrl}/sso-auth/google/dev`}
        class="flex items-center justify-center gap-3 w-full bg-white border border-gray-300 hover:border-gray-400 hover:shadow-sm text-gray-700 font-medium py-3 px-4 rounded-xl transition-all"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24">
          <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" />
          <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" />
          <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" />
          <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" />
        </svg>
        Đăng nhập với Google
      </a>

      <p class="text-center text-sm text-[#9bab92] mt-6">
        Chưa có tài khoản? <a href="/dang-ky" class="text-[#c0395b] hover:underline font-medium">Đăng ký</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  // Inline reCAPTCHA v3 helpers (không dùng module import vì không resolve được ở production)
  let _recaptchaScriptLoaded = false;
  let _recaptchaScriptPromise = null;

  function loadRecaptchaScript(siteKey) {
    if (_recaptchaScriptLoaded) return Promise.resolve();
    if (_recaptchaScriptPromise) return _recaptchaScriptPromise;
    _recaptchaScriptPromise = new Promise(function (resolve, reject) {
      var existing = document.querySelector('script[src="https://www.google.com/recaptcha/api.js?render=' + encodeURIComponent(siteKey) + '"]');
      if (existing) { _recaptchaScriptLoaded = true; resolve(); return; }
      var script = document.createElement('script');
      script.src = 'https://www.google.com/recaptcha/api.js?render=' + encodeURIComponent(siteKey);
      script.async = true;
      script.defer = true;
      script.onload = function () {
        _recaptchaScriptLoaded = true;
        (function wait() {
          if (window.grecaptcha && typeof window.grecaptcha.ready === 'function') {
            window.grecaptcha.ready(resolve);
          } else { setTimeout(wait, 50); }
        })();
      };
      script.onerror = function () { _recaptchaScriptPromise = null; reject(new Error('Failed to load reCAPTCHA')); };
      document.head.appendChild(script);
    });
    return _recaptchaScriptPromise;
  }

  function getRecaptchaToken(siteKey, action) {
    return new Promise(function (resolve, reject) {
      window.grecaptcha.ready(function () {
        window.grecaptcha.execute(siteKey, { action: action }).then(resolve).catch(reject);
      });
    });
  }

  var loginPage = document.getElementById('login-page');
  var siteKey = loginPage ? (loginPage.dataset.recaptchaSiteKey || '') : '';

  const form = document.getElementById('login-form') as HTMLFormElement;
  const errEl = document.getElementById('login-err')!;
  const submitBtn = document.getElementById('login-submit') as HTMLButtonElement;

  // Password toggle
  const toggleBtn = document.getElementById('login-toggle-pw') as HTMLButtonElement;
  const pwInput = document.getElementById('login_password') as HTMLInputElement;
  const eyeOff = document.getElementById('login-eye-off')!;
  const eyeOn = document.getElementById('login-eye-on')!;

  toggleBtn.addEventListener('click', () => {
    const isPassword = pwInput.type === 'password';
    pwInput.type = isPassword ? 'text' : 'password';
    eyeOff.classList.toggle('hidden', isPassword);
    eyeOn.classList.toggle('hidden', !isPassword);
  });

  // Check for error params from SSO callback redirect
  const urlParams = new URLSearchParams(window.location.search);
  const errorParam = urlParams.get('error');
  const reasonParam = urlParams.get('reason');

  if (errorParam === 'google_blocked' && reasonParam) {
    errEl.textContent = decodeURIComponent(reasonParam);
    errEl.classList.remove('hidden');
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errEl.classList.add('hidden');
    submitBtn.disabled = true;
    submitBtn.textContent = 'Đang xác minh...';

    const formData = new FormData(form);
    const body: Record<string, string> = {
      email: (formData.get('email') as string)?.trim() || '',
      password: (formData.get('password') as string) || '',
    };

    if (!body.email || !body.password) {
      errEl.textContent = 'Vui lòng nhập Email và Mật khẩu';
      errEl.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Đăng nhập';
      return;
    }

    try {
      if (siteKey) {
        await loadRecaptchaScript(siteKey);
        body.recaptchaToken = await getRecaptchaToken(siteKey, 'login');
      }
    } catch {
      // reCAPTCHA optional — proceed without token
    }

    submitBtn.textContent = 'Đang đăng nhập...';

    try {
      const res = await fetch('/api/auth/login-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      const data = await res.json().catch(() => null);

      if (res.ok && data?.redirect) {
        window.location.href = data.redirect;
      } else {
        errEl.textContent = data?.error || 'Đăng nhập thất bại, vui lòng thử lại';
        errEl.classList.remove('hidden');
      }
    } catch {
      errEl.textContent = 'Lỗi kết nối, vui lòng thử lại';
      errEl.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = 'Đăng nhập';
    }
  });

  // Forgot password toggle + submit
  const forgotLink = document.getElementById('forgot-pw-link') as HTMLButtonElement;
  const forgotForm = document.getElementById('forgot-pw-form') as HTMLFormElement;
  const forgotMsg = document.getElementById('forgot-msg')!;
  const forgotSubmit = document.getElementById('forgot-submit') as HTMLButtonElement;
  const forgotBack = document.getElementById('forgot-back') as HTMLButtonElement;

  forgotLink.addEventListener('click', () => {
    form.classList.add('hidden');
    forgotForm.classList.remove('hidden');
    forgotMsg.classList.add('hidden');
  });

  forgotBack.addEventListener('click', () => {
    forgotForm.classList.add('hidden');
    form.classList.remove('hidden');
    forgotMsg.classList.add('hidden');
  });

  forgotForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    forgotMsg.classList.add('hidden');
    forgotSubmit.disabled = true;
    forgotSubmit.textContent = 'Đang xác minh...';

    const formData = new FormData(forgotForm);
    const email = (formData.get('email') as string)?.trim() || '';

    if (!email) {
      forgotMsg.className = 'text-xs text-red-500';
      forgotMsg.textContent = 'Vui lòng nhập email';
      forgotMsg.classList.remove('hidden');
      forgotSubmit.disabled = false;
      forgotSubmit.textContent = 'Gửi yêu cầu';
      return;
    }

    const body: Record<string, string> = { email };

    try {
      if (siteKey) {
        await loadRecaptchaScript(siteKey);
        body.recaptchaToken = await getRecaptchaToken(siteKey, 'forgot_password');
      }
    } catch {
      // reCAPTCHA optional — proceed without token
    }

    forgotSubmit.textContent = 'Đang gửi...';

    try {
      const res = await fetch('/api/auth/forgot-password', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(body),
      });

      const data = await res.json().catch(() => null);

      if (data?.success) {
        forgotMsg.className = 'text-xs text-green-600';
        forgotMsg.textContent = 'Nếu email hợp lệ, hướng dẫn đặt lại mật khẩu đã được gửi.';
        forgotMsg.classList.remove('hidden');
      } else if (data?.code === 'GOOGLE_ACCOUNT') {
        forgotMsg.className = 'text-xs text-amber-600';
        forgotMsg.textContent = data.error || 'Email này đang sử dụng đăng nhập Google.';
        forgotMsg.classList.remove('hidden');
      } else {
        forgotMsg.className = 'text-xs text-red-500';
        forgotMsg.textContent = data?.error || 'Có lỗi xảy ra, vui lòng thử lại';
        forgotMsg.classList.remove('hidden');
      }
    } catch {
      forgotMsg.className = 'text-xs text-red-500';
      forgotMsg.textContent = 'Lỗi kết nối, vui lòng thử lại';
      forgotMsg.classList.remove('hidden');
    } finally {
      forgotSubmit.disabled = false;
      forgotSubmit.textContent = 'Gửi yêu cầu';
    }
  });
</script>
