---
import Layout from '@/layouts/BaseLayout.astro';

const { user, contact } = Astro.locals;
---

<Layout metadata={{ title: 'Tài khoản của tôi', description: 'Trang quản lý tài khoản Hồng Ngọc Huyền Học' }}>
  <div class="min-h-[70vh] px-4 py-16 max-w-3xl mx-auto">
    <div class="bg-white rounded-2xl shadow-lg p-8 border border-[#f5e1e0]">
      <h1 class="text-2xl font-bold text-[#1f2a1d] mb-6">Tài khoản của tôi</h1>

      <div class="space-y-4">
        <div class="p-4 bg-[#fcf5ee] rounded-xl">
          <span class="text-sm text-[#9bab92]">Họ tên</span>
          <p class="text-[#1f2a1d] font-medium">
            {contact?.first_name || user?.first_name || 'Chưa cập nhật'} {contact?.last_name || user?.last_name || ''}
          </p>
        </div>

        <div class="p-4 bg-[#fcf5ee] rounded-xl">
          <span class="text-sm text-[#9bab92]">Email</span>
          <p class="text-[#1f2a1d] font-medium">{user?.email || 'Chưa cập nhật'}</p>
        </div>

        <div class="p-4 bg-[#fcf5ee] rounded-xl">
          <span class="text-sm text-[#9bab92]">Điện thoại</span>
          <p class="text-[#1f2a1d] font-medium">{contact?.phone || 'Chưa cập nhật'}</p>
        </div>

        <div class="pt-4 flex gap-4">
          <a
            href="/tai-khoan/cap-nhat-thong-tin"
            class="inline-flex items-center px-5 py-2.5 bg-[#1f2a1d] text-white text-sm font-medium rounded-full hover:bg-[#850e35] transition-colors"
          >
            Cập nhật thông tin
          </a>
          <a
            href="/api/auth/logout"
            class="inline-flex items-center px-5 py-2.5 border border-[#e8d5d5] text-[#6b4f4f] text-sm font-medium rounded-full hover:bg-[#f5e1e0] transition-colors"
          >
            Đăng xuất
          </a>
        </div>
      </div>
    </div>
  </div>
</Layout>
