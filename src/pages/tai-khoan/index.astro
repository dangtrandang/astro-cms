---
import Layout from '@/layouts/BaseLayout.astro';
import { fetchPageData } from '@/lib/directus/fetchers';
import AccountDashboard from '@/components/blocks/AccountDashboard';

const { user, contact } = Astro.locals;

const DEFAULT_BLOCK_CONFIG = {
  id: '',
  default_tab: 'account-info',
  enabled_tabs: ['account-info', 'account-edit'],
  tab_labels: { 'account-info': 'Thông tin tài khoản', 'account-edit': 'Cập nhật thông tin' },
  allow_avatar_edit: false,
  allow_cover_edit: false,
  show_logout_button: true,
  support_content: '',
};

let blockConfig = DEFAULT_BLOCK_CONFIG;
try {
  const page = await fetchPageData('/tai-khoan', 1);
  const blockAccountRow = page?.blocks?.find(
    (b: any) => b?.collection === 'block_account' && b?.item && typeof b.item === 'object',
  );
  if (blockAccountRow?.item) {
    const raw = blockAccountRow.item;
    blockConfig = {
      id: raw.id || '',
      default_tab: raw.default_tab || 'account-info',
      enabled_tabs: Array.isArray(raw.enabled_tabs) ? raw.enabled_tabs : ['account-info', 'account-edit'],
      tab_labels: raw.tab_labels && typeof raw.tab_labels === 'object' ? raw.tab_labels : {},
      allow_avatar_edit: raw.allow_avatar_edit ?? false,
      allow_cover_edit: raw.allow_cover_edit ?? false,
      show_logout_button: raw.show_logout_button ?? true,
      support_content: raw.support_content || '',
    };
  }
} catch (err) {
  console.error('[tai-khoan] Failed to fetch block_account:', err);
}
---

<Layout metadata={{ title: 'Tài khoản của tôi', description: 'Trang quản lý tài khoản Hồng Ngọc Huyền Học' }}>
  <div class="min-h-[70vh] px-4 py-8 lg:py-12 max-w-5xl mx-auto">
    <AccountDashboard
      client:load
      user={user}
      contact={contact}
      blockConfig={blockConfig}
    />
  </div>
</Layout>
