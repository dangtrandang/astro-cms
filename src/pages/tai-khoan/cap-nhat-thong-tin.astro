---
import Layout from '@/layouts/BaseLayout.astro';

const { user, contact } = Astro.locals;
---

<Layout metadata={{ title: 'Cập nhật thông tin', description: 'Cập nhật thông tin tài khoản.' }}>
  <div class="min-h-[70vh] px-4 py-16 max-w-3xl mx-auto">
    <div class="bg-white rounded-2xl shadow-lg p-8 border border-[#f5e1e0]">
      <h1 class="text-2xl font-bold text-[#1f2a1d] mb-2">Cập nhật thông tin</h1>
      <p class="text-sm text-[#6b7a65] mb-6">Vui lòng cung cấp số điện thoại để hoàn tất thiết lập tài khoản</p>

      <form method="POST" action="/api/auth/update-contact" class="space-y-5">
        <div>
          <label for="first_name" class="block text-sm font-medium text-[#1f2a1d] mb-1">Họ</label>
          <input
            type="text"
            id="first_name"
            name="first_name"
            value={contact?.first_name || user?.first_name || ''}
            class="w-full px-4 py-2.5 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#c0395b]/30 focus:border-[#c0395b] outline-none transition"
          />
        </div>

        <div>
          <label for="last_name" class="block text-sm font-medium text-[#1f2a1d] mb-1">Tên</label>
          <input
            type="text"
            id="last_name"
            name="last_name"
            value={contact?.last_name || user?.last_name || ''}
            class="w-full px-4 py-2.5 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#c0395b]/30 focus:border-[#c0395b] outline-none transition"
          />
        </div>

        <div>
          <label for="phone" class="block text-sm font-medium text-[#1f2a1d] mb-1">
            Số điện thoại <span class="text-[#c0395b]">*</span>
          </label>
          <input
            type="tel"
            id="phone"
            name="phone"
            required
            placeholder="VD: 0912345678"
            value={contact?.phone || ''}
            class="w-full px-4 py-2.5 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#c0395b]/30 focus:border-[#c0395b] outline-none transition"
          />
        </div>

        <button
          type="submit"
          class="w-full bg-[#1f2a1d] hover:bg-[#850e35] text-white font-medium py-3 px-6 rounded-full transition-colors"
        >
          Lưu thông tin
        </button>
      </form>
    </div>
  </div>
</Layout>
