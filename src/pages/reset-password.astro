---
import Layout from '@/layouts/BaseLayout.astro';

const token = Astro.url.searchParams.get('token') || '';
---

<Layout metadata={{ title: 'Đặt lại mật khẩu', description: 'Đặt lại mật khẩu tài khoản Hồng Ngọc Huyền Học' }}>
  <div class="min-h-[70vh] flex items-center justify-center px-4 py-16">
    <div class="w-full max-w-md bg-white rounded-2xl shadow-lg p-8 border border-[#f5e1e0]">
      <div class="text-center mb-8">
        <h1 class="text-2xl font-bold text-[#1f2a1d] mb-2">Đặt lại mật khẩu</h1>
        <p class="text-sm text-[#6b7a65]">Nhập mật khẩu mới cho tài khoản của bạn</p>
        <div id="reset-msg" class="text-sm mt-2 hidden"></div>
      </div>

      {token ? (
        <form id="reset-form" class="space-y-4">
          <input type="hidden" id="reset-token" value={token} />
          <div>
            <label for="reset_password" class="block text-sm font-medium text-[#1f2a1d] mb-1">Mật khẩu mới</label>
            <div class="relative">
              <input
                type="password"
                id="reset_password"
                name="password"
                required
                minlength="8"
                autocomplete="new-password"
                placeholder="Tối thiểu 8 ký tự"
                class="w-full px-4 py-2.5 pr-10 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#C6DCE4]/30 focus:border-[#C6DCE4] outline-none transition"
              />
              <button
                type="button"
                id="reset-toggle-pw"
                class="absolute right-3 top-1/2 -translate-y-1/2 text-[#9bab92] hover:text-[#4a5a40] focus:outline-none"
                tabindex="-1"
                aria-label="Hiển thị mật khẩu"
              >
                <svg id="reset-eye-off" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24" />
                  <line x1="1" y1="1" x2="23" y2="23" />
                </svg>
                <svg id="reset-eye-on" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="hidden">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z" />
                  <circle cx="12" cy="12" r="3" />
                </svg>
              </button>
            </div>
          </div>
          <div>
            <label for="reset_confirm" class="block text-sm font-medium text-[#1f2a1d] mb-1">Xác nhận mật khẩu</label>
            <input
              type="password"
              id="reset_confirm"
              name="confirm"
              required
              autocomplete="new-password"
              placeholder="Nhập lại mật khẩu mới"
              class="w-full px-4 py-2.5 border border-[#e8d5d5] rounded-xl bg-white focus:ring-2 focus:ring-[#C6DCE4]/30 focus:border-[#C6DCE4] outline-none transition"
            />
          </div>
          <button
            type="submit"
            id="reset-submit"
            class="w-full bg-[#1f2a1d] hover:bg-[#2f3a2d] disabled:bg-[#9bab92] text-white font-medium py-3 px-6 rounded-full transition-colors"
          >
            Đặt lại mật khẩu
          </button>
        </form>
      ) : (
        <div class="text-center">
          <p class="text-red-500 text-sm mb-6">Liên kết không hợp lệ hoặc đã hết hạn.</p>
          <a href="/login" class="inline-block bg-[#1f2a1d] text-white font-medium py-2 px-6 rounded-xl hover:bg-[#2f3a2d] transition-colors">
            Về trang đăng nhập
          </a>
        </div>
      )}

      <p class="text-center text-sm text-[#9bab92] mt-6">
        <a href="/login" class="text-[#c0395b] hover:underline font-medium">Quay lại đăng nhập</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  const form = document.getElementById('reset-form') as HTMLFormElement | null;
  const msgEl = document.getElementById('reset-msg')!;
  const submitBtn = document.getElementById('reset-submit') as HTMLButtonElement | null;

  // Password toggle
  const toggleBtn = document.getElementById('reset-toggle-pw') as HTMLButtonElement | null;
  const pwInput = document.getElementById('reset_password') as HTMLInputElement | null;
  const eyeOff = document.getElementById('reset-eye-off');
  const eyeOn = document.getElementById('reset-eye-on');

  if (toggleBtn && pwInput && eyeOff && eyeOn) {
    toggleBtn.addEventListener('click', () => {
      const isPassword = pwInput.type === 'password';
      pwInput.type = isPassword ? 'text' : 'password';
      eyeOff.classList.toggle('hidden', isPassword);
      eyeOn.classList.toggle('hidden', !isPassword);
    });
  }

  if (form && submitBtn) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msgEl.classList.add('hidden');
      submitBtn.disabled = true;
      submitBtn.textContent = 'Đang xử lý...';

      const formData = new FormData(form);
      const password = (formData.get('password') as string)?.trim() || '';
      const confirm = (formData.get('confirm') as string)?.trim() || '';

      if (password.length < 8) {
        msgEl.className = 'text-sm text-red-500 mt-2';
        msgEl.textContent = 'Mật khẩu phải có ít nhất 8 ký tự';
        msgEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Đặt lại mật khẩu';
        return;
      }

      if (password !== confirm) {
        msgEl.className = 'text-sm text-red-500 mt-2';
        msgEl.textContent = 'Mật khẩu xác nhận không khớp';
        msgEl.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Đặt lại mật khẩu';
        return;
      }

      try {
        const res = await fetch('/api/auth/reset-password', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token: document.getElementById('reset-token')?.getAttribute('value') || '', password }),
        });

        const data = await res.json().catch(() => null);

        if (res.ok && data?.success) {
          window.location.href = '/login?reset=success';
        } else {
          msgEl.className = 'text-sm text-red-500 mt-2';
          msgEl.textContent = data?.error || 'Đặt lại mật khẩu thất bại, thử lại sau';
          msgEl.classList.remove('hidden');
        }
      } catch {
        msgEl.className = 'text-sm text-red-500 mt-2';
        msgEl.textContent = 'Lỗi kết nối, vui lòng thử lại';
        msgEl.classList.remove('hidden');
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = 'Đặt lại mật khẩu';
      }
    });
  }
</script>
