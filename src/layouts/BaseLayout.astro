---
import NavigationBar from '@/components/layout/NavigationBar';
import Footer from '@/components/layout/Footer';
import { getDirectusAssetURL } from '@/lib/directus/directus-utils';
import { fetchSiteData } from '@/lib/directus/fetchers';
import '@/styles/global.css';

const { globals, headerNavigation, footerNavigation } = await fetchSiteData();

const siteTitle = globals?.title || 'Simple CMS';
const siteDescription = globals?.description || 'A starter CMS template powered by Directus and Astro.';
const faviconURL = globals?.favicon ? getDirectusAssetURL(globals.favicon) : '/favicon.ico';
const accentColor = globals?.accent_color || '#6644ff';

const { metadata, headerVariant = 'default' } = Astro.props;

const fullTitle = metadata?.title ? `${metadata.title} | ${siteTitle}` : siteTitle;
---
<html lang="en" style={`--accent-color: ${accentColor};`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400..700;1,400..700&family=Libertinus+Serif:ital,wght@0,400;0,700;1,400&display=swap" />
    <title>{fullTitle}</title>
    <meta name="description" content={metadata?.description || siteDescription} />
    <link rel="icon" href={faviconURL} />

    {metadata?.openGraph && (
      <>
        <meta property="og:title" content={metadata.openGraph.title} />
        <meta property="og:description" content={metadata.openGraph.description} />
        <meta property="og:url" content={metadata.openGraph.url} />
        <meta property="og:type" content={metadata.openGraph.type} />
      </>
    )}

    {metadata?.robots && (
      <meta name="robots" content={metadata.robots} />
    )}

    {metadata?.canonical && (
      <link rel="canonical" href={metadata.canonical} />
    )}

    {metadata?.openGraph?.images && (
      metadata.openGraph.images.map((img: any, i: number) => (
        <meta property="og:image" content={img.url} />
      ))
    )}

    {metadata?.twitter?.card && (
      <>
        <meta name="twitter:card" content={metadata.twitter.card} />
        {metadata.twitter.title && <meta name="twitter:title" content={metadata.twitter.title} />}
        {metadata.twitter.description && <meta name="twitter:description" content={metadata.twitter.description} />}
        {metadata.twitter.image && <meta name="twitter:image" content={metadata.twitter.image} />}
      </>
    )}


    <style is:inline>
      /* ── Top Progress Bar (Gradient Pill) ── */
      #top-progress-bar {
        position: fixed;
        top: 0;
        left: 0;
        height: 4px;
        width: 0;
        border-radius: 0 100px 100px 0;
        background: linear-gradient(to right, #c0395b 0%, #e8676b 40%, #f1907c 75%, #f5b7a8 100%) !important;
        box-shadow:
          0 0 6px rgba(232, 103, 107, 0.45),
          0 0 14px rgba(192, 57, 91, 0.25),
          0 0 22px rgba(192, 57, 91, 0.12);
        z-index: 999999;
        pointer-events: none;
        opacity: 0;
        transition: width 0.3s ease, opacity 0.25s ease;
      }
      #top-progress-bar.active {
        opacity: 1;
      }
    </style>

    <script is:inline>
      // ── Top Progress Bar (trickle algorithm) ──
      (function () {
        var timer = null;
        var w = 0;
        var TRICKLE_RATE = 0.08;
        var TRICKLE_INTERVAL = 400;
        var DONE_HOLD = 200;
        var FADE_RESET = 300;

        // Lookup bar mỗi lần gọi vì script nằm trong <head>, body chưa parse
        function getBar() {
          return document.getElementById('top-progress-bar');
        }

        function clear() {
          if (timer) { clearTimeout(timer); timer = null; }
        }

        function trickle() {
          var bar = getBar();
          if (!bar) return;
          if (w < 85) {
            w += (100 - w) * TRICKLE_RATE;
            bar.style.width = w + '%';
            timer = setTimeout(trickle, TRICKLE_INTERVAL);
          }
        }

        function start() {
          clear();
          w = 0;
          var bar = getBar();
          if (!bar) return;
          bar.classList.add('active');
          bar.style.width = '0';
          requestAnimationFrame(function () {
            var b = getBar();
            if (b) { void b.offsetHeight; }
            trickle();
          });
        }

        function done() {
          clear();
          var bar = getBar();
          if (!bar) return;
          bar.style.width = '100%';
          setTimeout(function () {
            var b = getBar();
            if (!b) return;
            b.classList.remove('active');
            setTimeout(function () {
              var b2 = getBar();
              if (b2) b2.style.width = '0';
            }, FADE_RESET);
          }, DONE_HOLD);
        }

        // ── SPA: attach listener ngay, không cần DOM sẵn sàng ──
        document.addEventListener('astro:before-preparation', start);
        document.addEventListener('astro:page-load', done);

        // ── Cold load / SPA swap: đợi DOM sẵn sàng ──
        if (!window._barColdStarted) {
          // Lần đầu tiên (cold load): đợi DOM rồi start
          window._barColdStarted = true;
          function coldStart() {
            if (document.readyState === 'complete') return; // cache load
            start();
            if (document.readyState === 'complete') { done(); }
            else { window.addEventListener('load', done); }
          }
          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', coldStart);
          } else {
            coldStart();
          }
        } else {
          // SPA swap: page mới có thể đã load xong, gọi done() ngay
          // Nếu chưa load xong, astro:page-load sẽ gọi done()
          if (document.readyState === 'complete') {
            // Page đã load xong — nhưng astro:before-preparation đã fire
            // ở page cũ. Page mới không cần start, chỉ cần done.
            done();
          }
        }
      })();
    </script>

    <script is:inline>
      // ── WebMCP: expose site tools to AI agents ──
      (function () {
        try {
          if (typeof navigator.modelContext === 'undefined' ||
              typeof navigator.modelContext.provideContext !== 'function') {
            return; // WebMCP API not available
          }

          navigator.modelContext.provideContext({
            tools: [{
              name: 'search_site',
              description: 'Search across all pages and blog posts on Hồng Ngọc Huyền Học',
              inputSchema: {
                type: 'object',
                properties: {
                  query: { type: 'string', description: 'Search term to find content' }
                },
                required: ['query']
              },
              execute: async (args) => {
                const res = await fetch('/api/search?query=' + encodeURIComponent(args.query));
                const json = await res.json();
                return json;
              }
            }]
          });
        } catch (_) {
          // WebMCP API unavailable — safe to ignore
        }
      })();
    </script>

  </head>
  <body class="antialiased font-body flex flex-col min-h-screen bg-cream text-charcoal">
    <!-- Top Progress Bar: ngay sau mở body, trước mọi nội dung -->
    <div id="top-progress-bar"></div>

    <NavigationBar
      variant={headerVariant}
      navigation={headerNavigation}
      globals={globals}
      currentPathname={Astro.url.pathname}
      client:load
    />
    <main class="flex-grow">
      <slot />
    </main>
    <Footer
      navigation={footerNavigation}
      globals={globals}
      client:load
    />

  </body>
</html>
